@page "/clientes"
@attribute [Authorize]
@inject ClientesService ClientesService
@inject SharedService Shared
@inject HttpClient Http
@inject IJSRuntime JSRuntime

@using LidyDecorApp.Web.Models;
@using LidyDecorApp.Web.Services
@using Microsoft.AspNetCore.Authorization

<PageTitle>Clientes</PageTitle>

<div class="d-flex justify-content-between align-items-center mb-3">
    <h1>Lista de Clientes</h1>
    <button class="btn btn-primary bi bi-plus" @onclick="() => Shared.OpenAddModal(ref clientesEdicao, ref isEditMode, ref showModal)"></button>
</div>

@if (!string.IsNullOrEmpty(alertMessage))
{
    <div class="alert alert-@alertMessageType alert-dismissible fade show" role="alert">
        @alertMessage
        <button type="button" class="btn-close" aria-label="Close" @onclick="async () => await SharedService.CloseAlert(ref alertMessage, ref alertMessageType, ref alertVisible)"></button>
    </div>
}

@if (showModal)
{
    <div class="modal-backdrop fade show"></div>
    <div class="modal fade show d-block"
         tabindex="-1"
         aria-labelledby="editModalLabel"
         aria-modal="true"
         role="dialog"
    @onclick:stopPropagation
         @onkeydown="@(e => { if (e.Key == "Escape") showModal =  SharedService.HideModal(HideModalCallback, showModal, StateHasChanged).Result; })">
        <div class="modal-dialog modal-lg modal-dialog-centered modal-dialog-scrollable">
            <div class="modal-content shadow-lg border-0">
                <div class="modal-header bg-primary text-white">
                    <h5 class="modal-title fw-bold" id="editModalLabel">
                        <i class="bi @(isEditMode ? "bi-pencil-square" : "bi-person-plus-fill") me-2"></i>
                        @((isEditMode ? "Editar Cliente" : "Novo Cliente"))
                    </h5>
                    <button type="button" class="btn-close btn-close-white" @onclick="async () => showModal = await SharedService.HideModal(HideModalCallback, showModal, StateHasChanged)" aria-label="Close"></button>
                </div>

                <div class="modal-body p-4">
                    <!-- Informações Pessoais / Contato -->
                    <div class="card mb-4 border-0 bg-light">
                        <div class="card-body">
                            <h6 class="text-primary fw-bold mb-3"><i class="bi bi-person me-1"></i> Informações Pessoais & Contato</h6>
                            <div class="row g-3">
                                <div class="col-md-6">
                                    <label for="nome" class="form-label fw-semibold">Nome Completo *</label>
                                    <input type="text" id="nome" @bind="clientesEdicao.Nome" class="form-control" placeholder="Nome do cliente" />
                                </div>

                                <div class="col-md-6">
                                    <label for="cpfCnpj" class="form-label fw-semibold">CPF / CNPJ</label>
                                    <input type="text" id="cpfCnpj" @bind="clientesEdicao.CpfCnpj" class="form-control" placeholder="000.000.000-00" />
                                </div>

                                <div class="col-md-6">
                                    <label for="email" class="form-label fw-semibold">E-mail</label>
                                    <input type="email" id="email" @bind="clientesEdicao.Email" class="form-control" placeholder="cliente@email.com" />
                                </div>

                                <div class="col-md-6">
                                    <label for="telefone" class="form-label fw-semibold">Telefone / WhatsApp</label>
                                    <input type="tel" id="telefone" @bind="clientesEdicao.Telefone" class="form-control" placeholder="(00) 00000-0000" />
                                </div>
                            </div>
                        </div>
                    </div>

                    <!-- Endereço -->
                    <div class="card border-0 bg-light">
                        <div class="card-body">
                            <h6 class="text-primary fw-bold mb-3"><i class="bi bi-geo-alt me-1"></i> Endereço</h6>
                            <div class="row g-3">
                                <div class="col-md-4">
                                    <label for="cep" class="form-label fw-semibold">CEP</label>
                                    <div class="input-group">
                                        <input type="text" id="cep" 
                                               @bind="clientesEdicao.Cep" 
                                               @bind:event="oninput"
                                               @bind:after="OnCepChanged"
                                               @onblur="BuscarCep"
                                               class="form-control" 
                                               placeholder="00000-000" 
                                               maxlength="9" />
                                        <button class="btn btn-outline-primary" type="button" @onclick="BuscarCep" disabled="@isBuscandoCep" title="Buscar CEP ViaCEP">
                                            @if (isBuscandoCep)
                                            {
                                                <span class="spinner-border spinner-border-sm" role="status" aria-hidden="true"></span>
                                            }
                                            else
                                            {
                                                <i class="bi bi-search"></i>
                                            }
                                        </button>
                                    </div>
                                    @if (!string.IsNullOrEmpty(cepError))
                                    {
                                        <small class="text-danger d-block mt-1">@cepError</small>
                                    }
                                </div>

                                <div class="col-md-8">
                                    <label for="logradouro" class="form-label fw-semibold">Logradouro / Rua</label>
                                    <input type="text" id="logradouro" @bind="clientesEdicao.Logradouro" class="form-control" placeholder="Rua, Avenida, Alameda..." />
                                </div>

                                <div class="col-md-4">
                                    <label for="numero" class="form-label fw-semibold">Número</label>
                                    <input type="text" id="numero" @bind="clientesEdicao.Numero" class="form-control" placeholder="Ex: 123" />
                                </div>

                                <div class="col-md-8">
                                    <label for="bairro" class="form-label fw-semibold">Bairro</label>
                                    <input type="text" id="bairro" @bind="clientesEdicao.Bairro" class="form-control" placeholder="Bairro" />
                                </div>

                                <div class="col-md-8">
                                    <label for="cidade" class="form-label fw-semibold">Cidade</label>
                                    <input type="text" id="cidade" @bind="clientesEdicao.Cidade" class="form-control" placeholder="Cidade" />
                                </div>

                                <div class="col-md-4">
                                    <label for="estado" class="form-label fw-semibold">Estado (UF)</label>
                                    <input type="text" id="estado" @bind="clientesEdicao.Estado" class="form-control" placeholder="SP" maxlength="2" />
                                </div>
                            </div>
                        </div>
                    </div>
                </div>

                <div class="modal-footer bg-light">
                    <button type="button" class="btn btn-secondary px-4" @onclick="async () => showModal = await SharedService.HideModal(HideModalCallback, showModal, StateHasChanged)">Cancelar</button>
                    <button type="button" class="btn btn-primary px-4 fw-bold" @onclick="SalvarClientes">
                        <i class="bi bi-check-lg me-1"></i> @((isEditMode ? "Salvar Alterações" : "Cadastrar Cliente"))
                    </button>
                </div>
            </div>
        </div>
    </div>
}

@if (clientes == null)
{
    <p><em>Carregando...</em></p>
}
else
{
    <TabelaClientes Clientes="clientes" EditarClientes="(clientes) => { cepError = null; Shared.OpenEditModal(ref clientesEdicao, clientes, ref isEditMode, ref showModal); }" ExcluirClientes="ExcluirClientes" />
}

@code {
    private bool showModal = false;
    private bool isEditMode = false;
    private ClientesModel clientesEdicao = new ClientesModel();
    private List<ClientesModel>? clientes;
    private string? alertMessage;
    private string? alertMessageType;
    private bool alertVisible;
    private EventCallback HideModalCallback { get; set; }
    private EventCallback<ClientesModel> SalvarClientesCallback { get; set; }

    private bool isBuscandoCep = false;
    private string? cepError;

    protected override async Task OnInitializedAsync()
    {
        clientes = await ClientesService.GetClientesFromApi();
    }

    private async Task OnCepChanged()
    {
        var clean = GetOnlyNumbers(clientesEdicao.Cep);
        if (clean.Length == 8)
        {
            await BuscarCep();
        }
    }

    private string GetOnlyNumbers(string? input)
    {
        if (string.IsNullOrEmpty(input)) return string.Empty;
        return new string(input.Where(char.IsDigit).ToArray());
    }

    private async Task BuscarCep()
    {
        cepError = null;
        var numbersOnly = GetOnlyNumbers(clientesEdicao.Cep);

        if (string.IsNullOrWhiteSpace(numbersOnly)) return;

        if (numbersOnly.Length != 8)
        {
            cepError = "CEP inválido. Deve possuir 8 dígitos.";
            return;
        }

        try
        {
            isBuscandoCep = true;
            StateHasChanged();

            using var viaCepClient = new HttpClient();
            var result = await viaCepClient.GetFromJsonAsync<ViaCepModel>($"https://viacep.com.br/ws/{numbersOnly}/json/");

            if (result != null && !result.IsErro)
            {
                if (!string.IsNullOrWhiteSpace(result.Logradouro)) clientesEdicao.Logradouro = result.Logradouro;
                if (!string.IsNullOrWhiteSpace(result.Bairro)) clientesEdicao.Bairro = result.Bairro;
                if (!string.IsNullOrWhiteSpace(result.Cidade)) clientesEdicao.Cidade = result.Cidade;
                if (!string.IsNullOrWhiteSpace(result.Estado)) clientesEdicao.Estado = result.Estado;

                clientesEdicao.Cep = $"{numbersOnly.Substring(0, 5)}-{numbersOnly.Substring(5)}";
            }
            else
            {
                cepError = "CEP não encontrado.";
            }
        }
        catch (Exception)
        {
            cepError = "Falha ao consultar a API ViaCEP.";
        }
        finally
        {
            isBuscandoCep = false;
            StateHasChanged();
        }
    }
        
    private async Task ExcluirClientes(int idClientes)
    {
        alertMessage = null;
        alertMessageType = null;
        HttpResponseMessage response = await ClientesService.ExcluirClientes(idClientes);

        if (response.IsSuccessStatusCode)
        {
            alertMessage = "Clientes exluido com sucesso!";
            alertMessageType = "success";
            clientes = await ClientesService.GetClientesFromApi();
        }
        else
        {
            var errorContent = await response.Content.ReadAsStringAsync();
            alertMessage = $"Erro ao excluir o clientes: {errorContent}";
            alertMessageType = "danger";
        }
    }
        
    private async Task SalvarClientes()
    {
        alertMessage = null;
        alertMessageType = null;

        HttpResponseMessage response = await ClientesService.SalvarClientes(clientesEdicao, isEditMode);

        if (response.IsSuccessStatusCode)
        {
            alertMessage = isEditMode ? "Clientes editado com sucesso!" : "Clientes adicionado com sucesso!";
            alertMessageType = "success";
            clientes = await ClientesService.GetClientesFromApi();
        }
        else
        {
            var errorContent = await response.Content.ReadAsStringAsync();
            alertMessage = $"Erro ao {(isEditMode ? "salvar" : "adicionar")} o clientes: {errorContent}";
            alertMessageType = "danger";
        }

        SharedService.ShowAlert(ref alertVisible);
        showModal = await SharedService.HideModal(HideModalCallback, showModal, StateHasChanged);
    }
}
